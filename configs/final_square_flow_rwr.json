            {
                "path": "datasets/square/ph/image_v15_train_visualdr.hdf5",
                "weight": 0.4
            }
        ],
        "output_dir": "./square_flow_rwr_v2_curriculum_logs",
        "normalize_weights_by_ds_size": false,
        "num_data_workers": 4,
        "hdf5_cache_mode": "low_dim",
