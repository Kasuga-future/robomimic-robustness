            "num_train_steps_per_iter": 16,
            "rollout_horizon": 400,
            "terminate_on_success": true,
            "demo_batch_ratio": 0.5,
            "eval_interval": 0,
            "save_interval": 25,
            "num_eval_episodes": 0,
            "environment_curriculum": {
                "enabled": true,
                "easy_env": "NutAssemblySquare",
                "hard_env": "NutAssemblySquareTrainVisualDR",
                "phases": [
                    {
                        "name": "warm_mixed_75easy_25hard",
                        "start_epoch": 1,
                        "end_epoch": 25,
                        "easy_workers": 12,
                        "hard_workers": 4
                    },
                    {
                        "name": "balanced_50easy_50hard",
                        "start_epoch": 26,
                        "end_epoch": 75,
                        "easy_workers": 8,
                        "hard_workers": 8
                    },
                    {
                        "name": "hard_majority_25easy_75hard",
                        "start_epoch": 76,
                        "end_epoch": 125,
                        "easy_workers": 4,
                        "hard_workers": 12
                    },
                    {
                        "name": "hard_dominant_12easy_88hard",
                        "start_epoch": 126,
                        "end_epoch": 175,
                        "easy_workers": 2,
                        "hard_workers": 14
                    },
                    {
                        "name": "full_visualdr",
                        "start_epoch": 176,
                        "end_epoch": 200,
                        "easy_workers": 0,
                        "hard_workers": 16
                    }
                ]
            }
        }
    },
    "algo": {
        "optim_params": {
            "policy": {
                "optimizer_type": "adamw",
                "learning_rate": {
                    "initial": 1e-05,
                    "decay_factor": 0.1,
                    "step_every_batch": true,
                    "scheduler_type": "cosine",
                    "num_cycles": 0.5,
                    "warmup_steps": 200,
                    "epoch_schedule": []
                },
                "regularization": {
                    "L2": 1e-06
                }
            }
        },
        "horizon": {
            "observation_horizon": 2,
            "action_horizon": 8,
            "prediction_horizon": 16
        },
        "unet": {
            "enabled": true,
            "diffusion_step_embed_dim": 256,
            "down_dims": [
                256,
                512,
                1024
            ],
            "kernel_size": 5,
            "n_groups": 8
        },
        "ema": {
            "enabled": true,
            "power": 0.75
        },
        "flow": {
            "num_train_timesteps": 100,
            "num_inference_steps": 20,
            "solver": "euler"
        },
        "rwr": {
            "gamma": 0.99,
            "reward_temperature": 2.0,
            "min_weight": 0.05,
            "max_weight": 6.0,
            "topk_fraction": 1.0,
            "lambda_online": 0.2,
            "use_staged_reward": true,
            "use_segment_level_weighting": true,
            "group_advantages_by_stage": true,
            "success_bonus": 5.0,
            "grasp_bonus": 1.0,
            "lift_bonus": 1.0,
            "hover_bonus": 1.0,
            "stable_grasp_steps": 3,
            "stable_hover_steps": 3,
            "grasp_threshold": 0.3,
            "lift_threshold": 0.4,
            "hover_threshold": 0.6,
            "use_geometric_hover": true,
            "hover_xy_threshold": 0.05,
            "advantage_eps": 1e-06,
            "curriculum": {
                "enabled": true,
                "schedule": "cosine",
                "decay_iters": 200,
                "early_stage_weights": {
                    "stable_grasp": 1.0,
                    "lift": 2.5,
                    "hover": 1.5,
                    "success": 3.0
                },
                "late_stage_weights": {
                    "stable_grasp": 0.2,
                    "lift": 0.6,
                    "hover": 2.0,
                    "success": 4.0
                }
            },
            "group_advantages_by_env_stage": true,
            "adaptive_stage_curriculum": {
                "enabled": true,
                "ema_beta": 0.9,
                "prior_success": 2.0,
                "prior_failure": 2.0,
                "deficit_gamma": 1.5,
                "strength": 1.25,
                "min_multiplier": 0.7,
                "max_multiplier": 1.8,
                "min_focus_episodes": 4,
                "min_priorities": {
                    "stable_grasp": 0.15,
                    "lift": 0.3,
                    "hover": 0.5,
                    "success": 1.0
                },
                "max_priorities": {
                    "stable_grasp": 2.0,
                    "lift": 4.5,
                    "hover": 5.0,
                    "success": 6.0
                }
            }
        }
    },
    "observation": {
        "modalities": {
